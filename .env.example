# ─────────────────────────────────────────────
#  JLPT RPG 환경변수
# ─────────────────────────────────────────────
# 이 파일을 복사하여 .env.local 파일을 만들고 실제 값을 채워넣으세요.
# .env.local 은 git 에 커밋되지 않습니다 (.gitignore 에 포함됨).
#
# Vercel 에 배포할 때는 동일한 키를 Project Settings → Environment Variables
# 에 등록해야 합니다.

# ── (클라이언트) Supabase ─────────────────────
# Supabase 대시보드 > Project Settings > API
#   Project URL  -> VITE_SUPABASE_URL
#   anon public  -> VITE_SUPABASE_ANON_KEY
#
# 두 변수가 모두 비어있으면 앱은 자동으로 "데모 모드(로컬 영속화)"로 동작합니다.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── (서버) 네이버 OAuth 콜백 / Supabase Admin ──
# Vercel Serverless Function (api/auth/naver/*) 에서만 사용됩니다.
# 클라이언트 번들에는 절대 노출되지 않습니다.
#
# 1) 네이버 개발자센터 (https://developers.naver.com/apps/) 에서 앱 등록 후
#    Client ID / Client Secret 을 발급받습니다.
# 2) Supabase Service Role Key 는 Project Settings > API > "service_role" 키.
#    절대로 클라이언트에 노출하지 마세요.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# (선택) 매직 링크가 돌아올 사이트 URL.
# 비어있으면 요청 origin 을 그대로 사용합니다.
# 운영시에는 https://jlpt-rpg.vercel.app 같은 절대 URL 권장.
SITE_URL=
